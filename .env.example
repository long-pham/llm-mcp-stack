# ===========================================
# LLM MCP Stack Environment Configuration
# ===========================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# ===========================================

# -------------------------------------------
# External Ports (Optional)
# -------------------------------------------
# Customize if defaults conflict with other services on your machine
SEARXNG_MCP_PORT=38081
CRAWL4AI_PORT=11235
MCPHUB_PORT=33000

# -------------------------------------------
# SearXNG - REQUIRED
# -------------------------------------------
# Auto-generated by start.sh if left as placeholder
# Generate manually with: openssl rand -hex 32
SEARXNG_SECRET_KEY=your-searxng-secret-here

# -------------------------------------------
# Crawl4AI (Optional)
# -------------------------------------------
# API token for authentication (leave empty for local use)
CRAWL4AI_API_TOKEN=
# Maximum concurrent crawling tasks
CRAWL4AI_MAX_TASKS=5
