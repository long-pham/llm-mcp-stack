# ===========================================
# LLM MCP Stack Environment Configuration
# ===========================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# ===========================================

# -------------------------------------------
# External Ports (Optional)
# -------------------------------------------
# Customize external ports if defaults conflict with other services
SEARXNG_PORT=38080
SEARXNG_MCP_PORT=38081
CRAWL4AI_PORT=11235
PAPER_SEARCH_PORT=38082
MCPHUB_PORT=3000

# -------------------------------------------
# SearXNG - REQUIRED
# -------------------------------------------
# Generate with: openssl rand -hex 32
SEARXNG_SECRET_KEY=your-searxng-secret-here
# Number of uWSGI workers and threads for SearXNG concurrency
SEARXNG_WORKERS=4
SEARXNG_THREADS=4

# -------------------------------------------
# Crawl4AI (Optional)
# -------------------------------------------
# API token for Crawl4AI authentication (leave empty if not needed)
CRAWL4AI_API_TOKEN=
# Maximum concurrent crawling tasks
CRAWL4AI_MAX_TASKS=10

# -------------------------------------------
# Paper Search - Academic Paper MCP (Optional)
# -------------------------------------------
PAPER_SEARCH_PORT=38082
# Comma-separated list of sources to enable (empty = all 18 sources)
# Available: arxiv,pubmed,pmc,biorxiv,medrxiv,google_scholar,iacr,semantic,crossref,sciencedirect,springer,ieee,scopus,acm,wos,jstor,researchgate,core
PAPER_SEARCH_SOURCES=
# Comma-separated list of sources to disable (ignored if SOURCES is set)
PAPER_SEARCH_DISABLED=

