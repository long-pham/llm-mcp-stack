# ===========================================
# LLM MCP Stack Environment Configuration
# ===========================================
# Copy this file to .env and fill in the required values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# ===========================================

# -------------------------------------------
# PostgreSQL (MetaMCP) - REQUIRED
# -------------------------------------------
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_USER=metamcp_user
POSTGRES_DB=metamcp_db
POSTGRES_HOST=metamcp-postgres
POSTGRES_PORT=5432
# Uncomment to expose Postgres externally (not recommended)
# POSTGRES_EXTERNAL_PORT=9433

# -------------------------------------------
# MetaMCP Authentication - REQUIRED
# -------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-auth-secret-here

# -------------------------------------------
# MetaMCP Application URLs
# -------------------------------------------
APP_URL=http://localhost:12008

# -------------------------------------------
# External Ports (Optional)
# -------------------------------------------
# Customize external ports if defaults conflict with other services
SEARXNG_PORT=38080
SEARXNG_MCP_PORT=38081
CRAWL4AI_PORT=11235
METAMCP_PORT=12008

# -------------------------------------------
# SearXNG - REQUIRED
# -------------------------------------------
# Generate with: openssl rand -hex 32
SEARXNG_SECRET_KEY=your-searxng-secret-here

# -------------------------------------------
# Crawl4AI (Optional)
# -------------------------------------------
# API token for Crawl4AI authentication (leave empty if not needed)
CRAWL4AI_API_TOKEN=
# Maximum concurrent crawling tasks
CRAWL4AI_MAX_TASKS=5

# -------------------------------------------
# OpenAI API-Compatible Claude Proxy
# -------------------------------------------
# Backend: "anthropic" (API) or "cli" (Claude Code CLI)
OPENAI_PROXY_BACKEND=anthropic
OPENAI_PROXY_PORT=8090
ANTHROPIC_API_KEY=
OPENAI_PROXY_DEFAULT_MODEL=claude-sonnet-4-5-20250929

# -------------------------------------------
# Docker Networking
# -------------------------------------------
# Enable localhost-to-docker translation for inter-container communication
TRANSFORM_LOCALHOST_TO_DOCKER_INTERNAL=true
